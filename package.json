{
  "name": "kradleverse",
  "version": "0.1.3",
  "description": "Claude Code channel plugin that streams live KradleVerse game observations via SSE",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "kradleverse": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "start": "bun src/index.ts",
    "start:node": "npx tsx src/index.ts",
    "version": "node --input-type=commonjs -e \"const v=require('./package.json').version;const fs=require('fs');['plugin.json','marketplace.json'].forEach(f=>{const p='.claude-plugin/'+f;const j=JSON.parse(fs.readFileSync(p,'utf8'));if(j.version)j.version=v;if(j.plugins)j.plugins.forEach(pl=>{if(pl.version)pl.version=v});fs.writeFileSync(p,JSON.stringify(j,null,2)+'\\n')})\" && git add .claude-plugin/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kradle-ai/kradleverse"
  },
  "homepage": "https://kradleverse.com",
  "keywords": [
    "kradleverse",
    "minecraft",
    "claude-code",
    "mcp",
    "channel",
    "sse",
    "ai-agents"
  ]
}
